generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum UserType {
  REGISTERED
  ANONYMOUS
}

enum SessionStatus {
  WAITING
  ACTIVE
  ENDED
}

enum MessageType {
  TEXT
  EMOJI
  GIF
  SYSTEM
}

enum BanType {
  TEMPORARY
  PERMANENT
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  REJECTED
}

enum ReportSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LogLevel {
  INFO
  WARN
  ERROR
  FATAL
}

// ============ USER MODELS ============

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(USER)
  isBanned      Boolean  @default(false)
  isOnline      Boolean  @default(false)
  lastSeen      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessionsAsUser1 ChatSession[] @relation("SessionUser1")
  sessionsAsUser2 ChatSession[] @relation("SessionUser2")
  messages        ChatMessage[] @relation("MessageSenderUser")
  reportsFiled    Report[]      @relation("ReportedByUser")
  reportsReceived Report[]      @relation("ReportedUser")
  bansReceived    Ban[]         @relation("BannedUser")
}

model AnonymousUser {
  id              String   @id @default(cuid())
  username        String
  gender          Gender   @default(UNKNOWN)
  fingerprintHash String   @unique
  ipHash          String
  isBanned        Boolean  @default(false)
  lastSeen        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessionsAsAnon1 ChatSession[] @relation("SessionAnon1")
  sessionsAsAnon2 ChatSession[] @relation("SessionAnon2")
  messages        ChatMessage[] @relation("MessageSenderAnon")
  reportsFiled    Report[]      @relation("ReportedByAnon")
  reportsReceived Report[]      @relation("ReportedAnon")
  bansReceived    Ban[]         @relation("BannedAnon")

  @@index([ipHash])
}

// ============ CHAT MODELS ============

model ChatSession {
  id             String        @id @default(cuid())
  status         SessionStatus @default(WAITING)

  user1Type      UserType
  user1Id        String?
  user1          User?         @relation("SessionUser1", fields: [user1Id], references: [id], onDelete: SetNull)
  user1Name      String?
  anon1Id        String?
  anon1          AnonymousUser? @relation("SessionAnon1", fields: [anon1Id], references: [id], onDelete: SetNull)

  user2Type      UserType?
  user2Id        String?
  user2          User?         @relation("SessionUser2", fields: [user2Id], references: [id], onDelete: SetNull)
  user2Name      String?
  anon2Id        String?
  anon2          AnonymousUser? @relation("SessionAnon2", fields: [anon2Id], references: [id], onDelete: SetNull)

  startedAt      DateTime      @default(now())
  endedAt        DateTime?
  duration       Int?
  endedById      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  messages       ChatMessage[]

  @@index([status])
  @@index([user1Id])
  @@index([user2Id])
  @@index([anon1Id])
  @@index([anon2Id])
}

model ChatMessage {
  id            String      @id @default(cuid())

  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  senderType    UserType
  senderId      String?
  sender        User?       @relation("MessageSenderUser", fields: [senderId], references: [id], onDelete: SetNull)
  senderName    String?
  anonSenderId  String?
  anonSender    AnonymousUser? @relation("MessageSenderAnon", fields: [anonSenderId], references: [id], onDelete: SetNull)

  content       String
  type          MessageType @default(TEXT)
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([sessionId, createdAt])
  @@index([senderId])
  @@index([anonSenderId])
}

// ============ MODERATION MODELS ============

model Report {
  id              String         @id @default(cuid())

  reporterType    UserType?
  reporterId      String?
  reporter        User?          @relation("ReportedByUser", fields: [reporterId], references: [id], onDelete: SetNull)
  reporterName    String?
  anonReporterId  String?
  anonReporter    AnonymousUser? @relation("ReportedByAnon", fields: [anonReporterId], references: [id], onDelete: SetNull)

  reportedType    UserType
  reportedId      String?
  reportedUser    User?          @relation("ReportedUser", fields: [reportedId], references: [id], onDelete: Cascade)
  reportedName    String?
  anonReportedId  String?
  anonReported    AnonymousUser? @relation("ReportedAnon", fields: [anonReportedId], references: [id], onDelete: Cascade)

  fingerprintHash String?
  ipHash          String?
  reason          String
  description     String?
  status          ReportStatus   @default(PENDING)
  severity        ReportSeverity @default(MEDIUM)
  chatSessionId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([reportedId])
  @@index([anonReportedId])
}

model Ban {
  id              String   @id @default(cuid())

  userType        UserType?
  userId          String?
  user            User?    @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  anonId          String?
  anonUser        AnonymousUser? @relation("BannedAnon", fields: [anonId], references: [id], onDelete: Cascade)

  fingerprintHash String?
  ipHash          String?
  reason          String
  type            BanType  @default(PERMANENT)
  duration        Int?
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  bannedById      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([fingerprintHash])
  @@index([ipHash])
}

// ============ SYSTEM MODELS ============

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel @default(INFO)
  action    String
  userId    String?
  userType  UserType?
  details   String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt
}

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  metric    String
  value     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([date, metric])
  @@index([date])
}
