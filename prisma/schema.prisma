generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // 🔴 ISSUE 1 Fixed: Scalable DB for production
  url      = env("DATABASE_URL")
}

// ============ ENUMS (🔴 ISSUE 2 & 8 Fixed) ============

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum UserType {
  REGISTERED
  ANONYMOUS
}

enum SessionStatus {
  WAITING
  ACTIVE
  ENDED
}

enum MessageType {
  TEXT
  EMOJI
  GIF
  SYSTEM
}

enum BanType {
  TEMPORARY
  PERMANENT
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  REJECTED
}

enum ReportSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LogLevel {
  INFO
  WARN
  ERROR
  FATAL
}

// ============ USER MODELS ============

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(USER)
  isBanned      Boolean  @default(false)
  isOnline      Boolean  @default(false)
  lastSeen      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations (🔴 ISSUE 3 Fixed: Explicit relations added)
  sessionsAsUser1 ChatSession[] @relation("SessionUser1")
  sessionsAsUser2 ChatSession[] @relation("SessionUser2")
  messages        ChatMessage[]
  reportsFiled    Report[]      @relation("ReportedByUser")
  reportsReceived Report[]      @relation("ReportedUser")
  bansReceived    Ban[]         @relation("BannedUser")
}

model AnonymousUser {
  id              String   @id @default(cuid())
  username        String
  gender          Gender   @default(UNKNOWN)
  fingerprintHash String   @unique // 🔴 ISSUE 5 Fixed + PII Protection (Hashes instead of raw data)
  ipHash          String           // PII Protection
  isBanned        Boolean  @default(false)
  lastSeen        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations (🔴 ISSUE 3 Fixed)
  sessionsAsAnon1 ChatSession[] @relation("SessionAnon1")
  sessionsAsAnon2 ChatSession[] @relation("SessionAnon2")
  messages        ChatMessage[]
  reportsFiled    Report[]      @relation("ReportedByAnon")
  reportsReceived Report[]      @relation("ReportedAnon")
  bansReceived    Ban[]         @relation("BannedAnon")

  @@index([ipHash])
}

// ============ CHAT MODELS ============

model ChatSession {
  id             String        @id @default(cuid())
  status         SessionStatus @default(WAITING)

  // --- User 1 (Initiator) ---
  user1Type      UserType
  user1Id        String?
  user1          User?         @relation("SessionUser1", fields: [user1Id], references: [id], onDelete: SetNull)
  anon1Id        String?
  anon1          AnonymousUser? @relation("SessionAnon1", fields: [anon1Id], references: [id], onDelete: SetNull)

  // --- User 2 (Matched) --- (🔴 ISSUE 4 Fixed: Empty string defaults removed, made nullable)
  user2Type      UserType?     
  user2Id        String?
  user2          User?         @relation("SessionUser2", fields: [user2Id], references: [id], onDelete: SetNull)
  anon2Id        String?
  anon2          AnonymousUser? @relation("SessionAnon2", fields: [anon2Id], references: [id], onDelete: SetNull)

  startedAt      DateTime      @default(now())
  endedAt        DateTime?
  duration       Int?          // in seconds
  endedById      String?       // Stores CUID of the user who ended it
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  messages       ChatMessage[]

  // 🔴 ISSUE 6 & 9 Fixed: Performance indexes
  @@index([status]) 
  @@index([user1Id])
  @@index([user2Id])
  @@index([anon1Id])
  @@index([anon2Id])
}

model ChatMessage {
  id            String      @id @default(cuid())
  
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Sender Polymorphic Relation
  senderType    UserType
  senderId      String?
  sender        User?       @relation(fields: [senderId], references: [id], onDelete: SetNull)
  anonSenderId  String?
  anonSender    AnonymousUser? @relation(fields: [anonSenderId], references: [id], onDelete: SetNull)

  content       String
  type          MessageType @default(TEXT)
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())

  // 🔴 ISSUE 6 Fixed: Composite index for fast message loading per session
  @@index([sessionId, createdAt]) 
  @@index([senderId])
  @@index([anonSenderId])
}

// ============ MODERATION MODELS ============

model Report {
  id              String         @id @default(cuid())

  // Reporter
  reporterType    UserType?
  reporterId      String?
  reporter        User?          @relation("ReportedByUser", fields: [reporterId], references: [id], onDelete: SetNull)
  anonReporterId  String?
  anonReporter    AnonymousUser? @relation("ReportedByAnon", fields: [anonReporterId], references: [id], onDelete: SetNull)

  // Reported User
  reportedType    UserType
  reportedId      String?
  reportedUser    User?          @relation("ReportedUser", fields: [reportedId], references: [id], onDelete: Cascade)
  anonReportedId  String?
  anonReported    AnonymousUser? @relation("ReportedAnon", fields: [anonReportedId], references: [id], onDelete: Cascade)

  fingerprintHash String?
  ipHash          String?
  reason          String
  description     String?
  status          ReportStatus   @default(PENDING)
  severity        ReportSeverity @default(MEDIUM)
  chatSessionId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([reportedId])
  @@index([anonReportedId])
}

model Ban {
  id              String   @id @default(cuid())

  userType        UserType?
  userId          String?
  user            User?    @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  anonId          String?
  anonUser        AnonymousUser? @relation("BannedAnon", fields: [anonId], references: [id], onDelete: Cascade)

  fingerprintHash String?
  ipHash          String?
  reason          String
  type            BanType  @default(PERMANENT)
  duration        Int?     // in minutes
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  bannedById      String?  // Admin/Moderator ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([fingerprintHash])
  @@index([ipHash])
}

// ============ SYSTEM MODELS ============

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel @default(INFO)
  action    String
  userId    String?  
  userType  UserType?
  details   String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string") // keeping string as it defines data format (e.g., "json", "boolean")
  description String?
  updatedAt   DateTime @updatedAt
}

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @db.Date // 🔴 ISSUE 7 Fixed: Specific Date format for PostgreSQL
  metric    String
  value     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([date, metric])
  @@index([date])
}  @@index([ipAddress])
}

// ============ SYSTEM MODELS ============

model SystemLog {
  id        String   @id @default(cuid())
  level     String   @default("info")
  action    String
  userId    String?
  userType  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt
}

model Analytics {
  id        String   @id @default(cuid())
  date      String
  metric    String
  value     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([date, metric])
  @@index([date])
}
